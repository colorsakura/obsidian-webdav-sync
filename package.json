{
  "name": "obsidian-webdav-sync",
  "version": "2.0.3",
  "main": "main.js",
  "scripts": {
    "dev": "bun run dev:plugin & bun run dev:webdav-explorer & wait",
    "dev:plugin": "bun esbuild.config.mjs",
    "dev:webdav-explorer": "bun run --filter webdav-explorer dev",
    "build": "bun run build:webdav-explorer && bun run build:plugin",
    "build:webdav-explorer": "bun run --filter webdav-explorer build",
    "build:plugin": "tsgo --noEmit --skipLibCheck && bun esbuild.config.mjs production",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "version": "bun version-bump.mjs && git add manifest.json versions.json",
    "format": "prettier --write 'src/**/*.ts' 'packages/**/*.ts'",
    "test": "vitest"
  },
  "devDependencies": {
    "@deanc/esbuild-plugin-postcss": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@types/diff-match-patch": "^1.0.36",
    "@types/glob-to-regexp": "^0.4.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^16.11.6",
    "@types/path-browserify": "^1.0.3",
    "@types/ramda": "^0.30.2",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@vitest/coverage-v8": "^4.1.5",
    "blob-polyfill": "^9.0.20240710",
    "core-js": "^3.41.0",
    "async-mutex": "^0.5.0",
    "bottleneck": "^2.19.5",
    "buffer": "^6.0.3",
    "bytes-iec": "^3.1.1",
    "consola": "^3.4.0",
    "crypto-browserify": "^3.12.1",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "fast-xml-parser": "^5.7.2",
    "fflate": "^0.8.2",
    "glob-to-regexp": "^0.4.1",
    "globals": "^17.6.0",
    "hash-wasm": "^4.12.0",
    "html-entities": "^2.6.0",
    "http-status-codes": "^2.3.0",
    "i18next": "^26.0.8",
    "js-base64": "^3.7.7",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "node-diff3": "^3.1.2",
    "obsidian": "latest",
    "ohash": "^2.0.11",
    "path-browserify": "^1.0.1",
    "postcss-merge-rules": "^7.0.4",
    "prettier": "^3.5.0",
    "ramda": "^0.32.0",
    "rxjs": "^7.8.1",
    "stream-browserify": "^3.0.0",
    "superjson": "^2.2.2",
    "tslib": "2.4.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "vitest": "^4.1.5",
    "webdav": "^5.9.0",
    "webdav-explorer": "workspace: *"
  },
  "browser": {
    "path": "path-browserify",
    "stream": "stream-browserify",
    "buffer": "buffer",
    "crypto": "crypto-browserify"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "moment": "^2.30.1",
    "sql.js": "^1.14.1",
    "webdav-server": "^2.6.2"
  }
}
